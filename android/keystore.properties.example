# Copy to android/keystore.properties and keep the real file local-only.
#
# The Go helper uses this file for non-secret metadata:
#   android-release setup
#   android-release bundle
#
# Passwords should come from environment variables injected by the Go helper:
#   VLESS_TUN_ANDROID_STORE_PASSWORD
#   VLESS_TUN_ANDROID_KEY_PASSWORD
#
# Optional local plaintext fallback exists for emergency/manual builds only:
#   storePassword=
#   keyPassword=

storeFile=keystore/upload.jks
keyAlias=upload
